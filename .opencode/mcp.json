{
  "mcpServers": {
    "filesystem": {
      "command": "pnpm",
      "args": ["dlx", "-y", "@modelcontextprotocol/server-filesystem", "/app"]
    },
    "github": {
      "command": "pnpm",
      "args": ["dlx", "-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "postgres": {
      "command": "pnpm",
      "args": ["dlx", "-y", "@modelcontextprotocol/server-postgres"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    },
    "memory": {
      "command": "pnpm",
      "args": ["dlx", "-y", "@modelcontextprotocol/server-memory"]
    }
  }
}